            }, {
                threshold: 0.2
            });

            observer.observe(target);
        }

        window.addEventListener('scroll', () => {
            const bonusBanner = document.querySelector('.bonus-banner');

            if (bonusBanner) {
                const newBigOne = bonusBanner.querySelector('.big-one');
                const newSmallOne = bonusBanner.querySelector('.small-one');

                if (newBigOne !== bigOne || newSmallOne !== smallOne) {
                    bigOne = newBigOne;
