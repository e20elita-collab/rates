                    // Details here: https://b2cdevapi.sunmar.ru/swagger/index.html#/OnlyHotelProduct/OnlyHotelProduct_ListArrivalLocations
                    async function getListArrivalLocations_hotels(
                        oh_destination,
                        oh_region
                    ) {
                        return new Promise(async (resolve, reject) => {
                            const sendData = {
                                text: oh_region || oh_destination,
                            };

                            try {
                                doRequestToServer(
                                    'https://b2capi.sunmar.ru/OnlyHotelProduct/ListArrivalLocations',
                                    sendData,
                                    'POST'
                                ).then(data => {
                                    const resultsArr = data.result.locations;
                                    let parent_id,
                                        region_id,
                                        region_type,
                                        region_name,
                                        region_friendlyUrl,
                                        country_friendlyUrl,
                                        country_id,
                                        country_name,
                                        country_type,
                                        parent_name,
                                        parent_type;

                                    if (!oh_region) {
                                        for (let item of resultsArr) {
                                            if (item.name === oh_destination) {
                                                country_name = item.name;
                                                country_id = item.id;
                                                country_friendlyUrl = item.friendlyUrl;
                                                country_type = item.type;

                                                break;
                                            }
                                        }
                                    } else {
                                        for (let item of resultsArr) {
                                            if (
                                                item.parent &&
                                                item.name.includes(oh_region) &&
                                                item.parent.name.includes(oh_destination)
                                            ) {
                                                const parentNameArr = item.parent.name.split(', ');
                                                if (
                                                    parentNameArr[parentNameArr.length - 1] ===
                                                    oh_destination
                                                ) {
                                                    country_name = oh_destination;
                                                    region_name = item.name;
                                                    parent_name = item.parent.name;
                                                    region_id = item.id;
                                                    region_friendlyUrl = item.friendlyUrl;
                                                    country_id = item.parent.countryId;
