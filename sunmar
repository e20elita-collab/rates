        }

        function observeJivo() {
            const observer = new MutationObserver(() => {
                if (isHiddenNow()) {
                    hideJivo();
                }

                const jivoBtn = document.querySelector('jdiv[class^="button__"]');
                if (jivoBtn && !jivoBtn.dataset.processed) {
                    jivoBtn.dataset.processed = 'true';
                    insertCloseBtn(jivoBtn);
                }
            });

            observer.observe(document.body, {
                childList: true,
                subtree: true
            });
        }

        function init() {
            if (window.innerWidth > 768) return;

            if (isHiddenNow()) {
                hideJivo();
            } else {
                showJivo();
            }

            observeJivo();
        }

        init();
    })();
