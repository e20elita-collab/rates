                for (const [name, fn] of H.listeners) {
                    try {
                        if (H.mark(evt, name)) fn(evt);
                    } catch (_) {}
                }
            }
            return origPush(...args);
        }

        Object.defineProperty(dl, 'push', {
            configurable: true,
            writable: true,
            value: wrappedPush
        });
        dl.__dlHub = {
            version: 1,
            at: Date.now()
        };

        try {
            dl.forEach(evt => {
