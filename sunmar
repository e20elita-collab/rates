            modal.querySelectorAll('.hint_btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const delayMin = parseInt(btn.dataset.delay, 10);
                    const hideUntil = Date.now() + delayMin * 60 * 100000;
