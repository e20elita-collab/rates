                 Поможем выбрать «куда»\n                    \u003c/h4\u003e\n                    \u003cp class=\"bento__text\"\u003e\n                        Бронируйте отдых в Турции, Египте, Вьетнаме, Таиланде и на Мальдивах на нашем сайте\n                    \u003c/p\u003e\n                \u003c/div\u003e\n\n                \u003cdiv class=\"bento__item bento__item--4\"\u003e\n                    \u003ch4 class=\"bento__title\"\u003e\n                        Поддержим в любое время\n                    \u003c/h4\u003e\n                    \u003cp class=\"bento__text\"\u003e\n                        Остаемся на связи в чатах, мессенджерах и по телефону на каждом этапе путешествия\n                    \u003c/p\u003e\n                \u003c/div\u003e\n\n                \u003cdiv class=\"bento__item bento__item--5\"\u003e\n                    \u003ch4 class=\"bento__title\"\u003e\n                        Найдем выход из любой ситуации\n                    \u003c/h4\u003e\n                    \u003cp class=\"bento__text\"\u003e\n                        Если какой-то маршрут или отель недоступен, подберем для вас альтернативные варианты\n                    \u003c/p\u003e\n                \u003c/div\u003e\n\n                \u003cdiv class=\"bento__item bento__item--6\"\u003e\n                    \u003ch4 class=\"bento__title\"\u003e\n                        Экономим ваш бюджет\n                    \u003c/h4\u003e\n                    \u003cp class=\"bento__text\"\u003e\n                        Предлагаем специальные условия, чтобы сделать ваш отдых еще выгоднее\n                    \u003c/p\u003e\n                    \u003ca href=\"https://www.sunmar.ru/info-actions/\" target=\"_blank\" class=\"bento__link\"\u003e\n                        Узнать больше\n                    \u003c/a\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n    \u003c/article\u003e\n\u003c/section\u003e","type":null},"order":16,"visibility":{"mo