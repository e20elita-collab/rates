        add(name, fn) {
            this.listeners.set(name, fn);
        },
        mark(evt, name) {
            let s = this.processedBy.get(evt);
            if (!s) {
                s = new Set();
                this.processedBy.set(evt, s);
            }
            return s.has(name) ? false : (s.add(name), true);
        }
