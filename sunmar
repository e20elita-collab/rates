    function sendMindbox(asyncMode, payload, onSuccess, onError, meta = {}) {
        if (typeof window.mindbox !== 'function') {
            return;
        }

        try {
            window.mindbox(asyncMode, payload, onSuccess, onError);
        } catch (error) {
            throw error;
        }
